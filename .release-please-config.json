{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "docker/alpine": {
      "release-type": "simple",
      "component": "alpine",
      "include-component-in-tag": true,
      "release-as": "8.4.22",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["docker/alpine/CHANGELOG.md"],
      "extra-files": [
        {
          "type": "generic",
          "path": "Dockerfile",
          "glob": false
        },
        {
          "type": "generic",
          "path": "Dockerfile.nginx",
          "glob": false
        }
      ]
    },
    "docker/debian": {
      "release-type": "simple",
      "component": "debian",
      "include-component-in-tag": true,
      "release-as": "8.4.16",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["docker/debian/CHANGELOG.md"],
      "extra-files": [
        {
          "type": "generic",
          "path": "Dockerfile",
          "glob": false
        },
        {
          "type": "generic",
          "path": "Dockerfile.nginx",
          "glob": false
        }
      ]
    },
    "docker/rocky": {
      "release-type": "simple",
      "component": "rocky",
      "include-component-in-tag": true,
      "release-as": "8.4.21",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["docker/rocky/CHANGELOG.md"],
